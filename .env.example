# ─────────────────────────────────────────────
# FIELD INTELLIGENCE OS — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to GitHub
# ─────────────────────────────────────────────

# Gemini API Key (free — aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Personal Access Token
# Create at: github.com/settings/tokens
# Scopes needed: repo (full control of private repositories)
GITHUB_TOKEN=your_github_token_here

# GitHub repo where context is stored
# Format: your-github-username/kanazi-context
GITHUB_REPO=your-username/kanazi-context

# Email delivery (free — resend.com)
# Create account, get API key, verify your domain
RESEND_API_KEY=your_resend_api_key_here

# Who receives the generated reports (comma-separated)
REPORT_RECIPIENTS=email1@example.com,email2@example.com

# Your email (the sender)
FROM_EMAIL=reports@yourdomain.com

# A simple password to protect the submission form
# Make this something only your team knows
ACCESS_PASSWORD=choose_a_password